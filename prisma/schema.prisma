generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int     @id @default(autoincrement())
  email    String  @unique
  name     String?
  orders   Order[]
}

model Product {
  id       Int     @id @default(autoincrement())
  name     String
  price    Float
  orders   Order[]
}

model Order {
  id        Int      @id @default(autoincrement())
  quantity  Int
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  product   Product  @relation(fields: [productId], references: [id])
  productId Int
}